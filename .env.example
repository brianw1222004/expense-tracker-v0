# Copy to .env and fill in from the Supabase dashboard (Settings -> API).
# EXPO_PUBLIC_ values are inlined into the client bundle at build time and are
# safe to expose: Row Level Security restricts what the anon key can do.
# After editing, restart the dev server and do a full reload in the app.
EXPO_PUBLIC_SUPABASE_URL=your-supabase-url-here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
